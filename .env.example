# PROXY_PORT=10808                              # 可选：HTTP 代理端口

# Guard 层是否启用
# 设置为 password 则启用，否则不启用
# ENV_RUNTIME_ACCESS_GUARD=off

# === OpenAI / 兼容 API 配置 ===
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-api-key-here
GPT_PRO=openai/gpt-5.4
GEM_PRO=google/gemini-3.1-pro-preview
GEM_FLASH=google/gemini-3-flash-preview
GEM_IMAGE=google/gemini-3.1-flash-image-preview

# === Lite 模型（轻量备用模型） ===
# LITE_BASE_URL=https://api.openai.com/v1
# LITE_API_KEY=sk-your-api-key-here
# LITE_MODEL=google/gemini-3.1-flash-lite-preview

# === Embedding 模型配置 ===
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-your-api-key-here

# === MinerU PDF 解析（可选） ===
# MINERU_KEY=your-mineru-key-here

# === Cloudflare R2 对象存储（可选，用于 PDF 远端传输） ===
# R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
# R2_BUCKET=pdf
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# R2_PUBLIC_BASE_URL=https://pub-your-account.r2.dev

# === Env unlock 密码哈希（可选） ===
# ENV_RUNTIME_PASSWORD_HASH=pbkdf2_sha256$...$...
